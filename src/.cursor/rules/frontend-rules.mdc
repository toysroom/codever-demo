  translations: {
    name: string;
    email: string;
    create: string;
    edit: string;
  };
}

export default function Index({ cargoProviders, translations }: Props) {
  return (
    <div>
      <h1>{translations.name}</h1>
      <CargoProviderTable 
        data={cargoProviders}
        translations={translations}
      />
    </div>
  );
