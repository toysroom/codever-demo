**Esempio Test Playwright:**

```typescript
// tests/E2E/Playwright/Domains/CargoProvider/create.spec.ts
import { test, expect } from '@playwright/test';

test.describe('CargoProvider - Create', () => {
  test.beforeEach(async ({ page }) => {
    // Login come Member Owner
    await page.goto('/login');
    await page.fill('input[name="email"]', 'owner@example.com');
    await page.fill('input[name="password"]', 'password');
    await page.click('button[type="submit"]');
    await page.waitForURL('/dashboard');
  });

  test('should create a new cargo provider', async ({ page }) => {
    // Naviga alla pagina di creazione
    await page.goto('/cargo-providers/create');
    
    // Compila il form
    await page.fill('input[name="name"]', 'Test Provider');
    await page.fill('input[name="email"]', 'test@provider.com');
    await page.fill('input[name="phone"]', '+39 123 456 7890');
    
    // Submit
    await page.click('button[type="submit"]');
    
    // Verifica redirect
    await expect(page).toHaveURL(/\/cargo-providers/);
    
    // Verifica success message o presenza del nuovo record
    await expect(page.locator('text=Test Provider')).toBeVisible();
  });

  test('should show validation errors', async ({ page }) => {
    await page.goto('/cargo-providers/create');
    
    // Submit senza compilare
    await page.click('button[type="submit"]');
    
    // Verifica errori
    await expect(page.locator('text=Il nome è obbligatorio')).toBeVisible();
    await expect(page.locator('text=L\'email è obbligatoria')).toBeVisible();
  });

  test('should validate email format', async ({ page }) => {
    await page.goto('/cargo-providers/create');
    
    await page.fill('input[name="name"]', 'Test Provider');
    await page.fill('input[name="email"]', 'invalid-email');
    await page.click('button[type="submit"]');
    
    await expect(page.locator('text=L\'email non è valida')).toBeVisible();
  });
});
```

