<?php

namespace App\Notifications\Member;

use Illuminate\Notifications\Notification;
use Illuminate\Notifications\Messages\MailMessage;

class WelcomeMemberNotification extends Notification
{
    public function via($notifiable): array
    {
        return ['mail', 'database'];
    }

    public function toMail($notifiable): MailMessage
    {
        return (new MailMessage)
            ->subject('Benvenuto in Zelante!')
            ->view('emails.member.welcome', [
                'member' => $notifiable,
            ]);
    }

    public function toArray($notifiable): array
    {
        return [
            'message' => 'Benvenuto in Zelante!',
            'action_url' => route('dashboard'),
        ];
    }
}

// Uso
$user->notify(new WelcomeMemberNotification());
```

## Ricerca e Filtri Avanzati

- Creare un pattern standard per ricerche e filtri
- Usare query scope o repository methods per filtri riutilizzabili
- Supportare filtri multipli, sorting, paginazione insieme

**Esempio Repository Pattern:**
```php
public function search(array $filters, array $sort = [], int $perPage = 15)
{
    $query = $this->model->newQuery();

    // Filtri
    if (isset($filters['name'])) {
        $query->where('name', 'like', "%{$filters['name']}%");
    }

    if (isset($filters['status'])) {
        $query->where('status', $filters['status']);
    }

    if (isset($filters['date_from'])) {
        $query->whereDate('created_at', '>=', $filters['date_from']);
    }

    // Sorting
    $sortColumn = $sort['column'] ?? 'created_at';
    $sortDirection = $sort['direction'] ?? 'desc';
    $query->orderBy($sortColumn, $sortDirection);

    // Paginazione
    return $query->paginate($perPage);
}
```

- Considerare pacchetti come Spatie Query Builder per filtri avanzati
- Supportare ricerca full-text quando necessario

## Operazioni Bulk (Batch)

- Per operazioni su multiple record, usare batch operations
- Usare transazioni per batch operations
- Validare e gestire errori per ogni record

**Esempio:**
```php
public function bulkUpdate(array $ids, array $data): array
{
    DB::beginTransaction();
    $results = ['success' => [], 'failed' => []];

    try {
        foreach ($ids as $id) {
            try {
                $model = $this->repository->find($id);
                $this->service->update($model, $data);
                $results['success'][] = $id;
            } catch (\Exception $e) {
                $results['failed'][] = ['id' => $id, 'error' => $e->getMessage()];
            }
        }

        DB::commit();
        return $results;
    } catch (\Exception $e) {
        DB::rollBack();
        throw $e;
    }
}
```

## Export e Import

- Implementare export in queue jobs per grandi dataset
- Supportare formati multipli (CSV, Excel, PDF)
- Validare e sanitizzare dati importati

**Esempio Export Job:**
```php
class ExportCargoProvidersJob implements ShouldQueue
{
    use Dispatchable, InteractsWithQueue, Queueable, SerializesModels;

    public function __construct(
        public int $memberId,
        public array $filters,
        public string $format = 'csv'
    ) {}

    public function handle()
    {
        $data = CargoProvider::where('member_id', $this->memberId)
            ->filter($this->filters)
            ->get();

        $filename = "export_".time().".{$this->format}";
        $path = "exports/{$this->memberId}/{$filename}";

        // Genera file e salva su storage
        Storage::disk('s3')->put($path, $this->generateFile($data));

        // Notifica utente che export è pronto
        auth()->user()->notify(new ExportReadyNotification($path));
    }
}
```

